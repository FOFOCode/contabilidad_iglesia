generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =====================
// CONFIGURACIONES DEL SISTEMA
// (Todas son tablas para CRUD dinámico)
// =====================

/// Monedas configurables del sistema
model Moneda {
  id            String    @id @default(cuid())
  codigo        String    @unique // USD, GTQ, EUR, etc.
  nombre        String    // Dólar estadounidense, Quetzal, Euro
  simbolo       String    // $, Q, €
  activa        Boolean   @default(true)
  esPrincipal   Boolean   @default(false)
  tasaCambio    Decimal   @default(1) @db.Decimal(12, 4)
  orden         Int       @default(0)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  creadoPorId   String?
  creadoPor     Usuario?  @relation("MonedaCreadoPor", fields: [creadoPorId], references: [id], onDelete: SetNull)
  actualizadoPorId String?
  actualizadoPor Usuario? @relation("MonedaActualizadoPor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)

  egresos        Egreso[]
  ingresosMontos IngresoMonto[]
  diezmosFiliales DiezmoFilial[]
  egresosFiliales EgresoFilial[]
  donaciones     Donacion[]

  // Índice para filtrar monedas activas (consulta muy frecuente)
  @@index([activa, orden])
  @@index([activa, esPrincipal])
  @@index([creadoPorId])
  @@index([actualizadoPorId])
  @@map("monedas")
}

/// Sociedades / Orígenes de recaudación
model Sociedad {
  id            String    @id @default(cuid())
  nombre        String    @unique
  descripcion   String?
  activa        Boolean   @default(true)
  orden         Int       @default(0)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  creadoPorId   String?
  creadoPor     Usuario?  @relation("SociedadCreadoPor", fields: [creadoPorId], references: [id], onDelete: SetNull)
  actualizadoPorId String?
  actualizadoPor Usuario? @relation("SociedadActualizadoPor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)

  ingresos Ingreso[]
  cajas    Caja[]

  // Índice para filtrar sociedades activas ordenadas
  @@index([activa, orden])
  @@index([creadoPorId])
  @@index([actualizadoPorId])
  @@map("sociedades")
}

/// Tipos de servicio religioso
model TipoServicio {
  id            String    @id @default(cuid())
  nombre        String    @unique
  descripcion   String?
  activo        Boolean   @default(true)
  orden         Int       @default(0)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  creadoPorId   String?
  creadoPor     Usuario?  @relation("TipoServicioCreadoPor", fields: [creadoPorId], references: [id], onDelete: SetNull)
  actualizadoPorId String?
  actualizadoPor Usuario? @relation("TipoServicioActualizadoPor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)

  ingresos Ingreso[]

  // Índice para filtrar tipos activos ordenados
  @@index([activo, orden])
  @@index([creadoPorId])
  @@index([actualizadoPorId])
  @@map("tipos_servicio")
}

/// Tipos de ingreso / procedencia del dinero
model TipoIngreso {
  id            String    @id @default(cuid())
  nombre        String    @unique
  descripcion   String?
  activo        Boolean   @default(true)
  orden         Int       @default(0)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  creadoPorId   String?
  creadoPor     Usuario?  @relation("TipoIngresoCreadoPor", fields: [creadoPorId], references: [id], onDelete: SetNull)
  actualizadoPorId String?
  actualizadoPor Usuario? @relation("TipoIngresoActualizadoPor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)

  ingresos   Ingreso[]
  cajas      Caja[]
  donaciones Donacion[]

  // Índice para filtrar tipos activos ordenados
  @@index([activo, orden])
  @@index([creadoPorId])
  @@index([actualizadoPorId])
  @@map("tipos_ingreso")
}

/// Tipos de gasto para egresos
model TipoGasto {
  id            String    @id @default(cuid())
  nombre        String    @unique
  descripcion   String?
  activo        Boolean   @default(true)
  orden         Int       @default(0)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  creadoPorId   String?
  creadoPor     Usuario?  @relation("TipoGastoCreadoPor", fields: [creadoPorId], references: [id], onDelete: SetNull)
  actualizadoPorId String?
  actualizadoPor Usuario? @relation("TipoGastoActualizadoPor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)

  egresos Egreso[]
  egresosFiliales EgresoFilial[]

  // Índice para filtrar tipos activos ordenados
  @@index([activo, orden])
  @@index([creadoPorId])
  @@index([actualizadoPorId])
  @@map("tipos_gasto")
}

/// Países para clasificar iglesias filiales
model Pais {
  id            String    @id @default(cuid())
  nombre        String    @unique
  codigo        String?   @unique // GT, US, MX, etc.
  activo        Boolean   @default(true)
  orden         Int       @default(0)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  creadoPorId   String?
  creadoPor     Usuario?  @relation("PaisCreadoPor", fields: [creadoPorId], references: [id], onDelete: SetNull)
  actualizadoPorId String?
  actualizadoPor Usuario? @relation("PaisActualizadoPor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)

  filiales Filial[]

  @@index([activo, orden])
  @@index([creadoPorId])
  @@index([actualizadoPorId])
  @@map("paises")
}

/// Iglesias filiales que envían diezmos
model Filial {
  id            String    @id @default(cuid())
  nombre        String    @unique // Nombre de la iglesia
  pastor        String    // Nombre del pastor
  activa        Boolean   @default(true)
  orden         Int       @default(0)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  creadoPorId   String?
  creadoPor     Usuario?  @relation("FilialCreadoPor", fields: [creadoPorId], references: [id], onDelete: SetNull)
  actualizadoPorId String?
  actualizadoPor Usuario? @relation("FilialActualizadoPor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)

  paisId        String
  pais          Pais      @relation(fields: [paisId], references: [id], onDelete: Restrict)

  diezmos       DiezmoFilial[]

  @@index([paisId])
  @@index([activa, orden])
  @@index([creadoPorId])
  @@index([actualizadoPorId])
  @@map("filiales")
}

/// Registro de diezmos de iglesias filiales (funciona como "mini caja" por filial)
model DiezmoFilial {
  id            String    @id @default(cuid())
  monto         Decimal   @db.Decimal(12, 2)
  mes           Int       // 1-12
  anio          Int       // Año de recaudación
  comentario    String?   @db.Text
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt

  filialId      String
  filial        Filial    @relation(fields: [filialId], references: [id], onDelete: Restrict)

  monedaId      String
  moneda        Moneda    @relation(fields: [monedaId], references: [id], onDelete: Restrict)

  usuarioId     String
  usuario       Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Restrict)
  
  // Auditoría: quién creó y quién modificó
  creadoPorId      String
  creadoPor        Usuario   @relation("DiezmoFilialCreadoPor", fields: [creadoPorId], references: [id], onDelete: Restrict)
  actualizadoPorId String?
  actualizadoPor   Usuario?  @relation("DiezmoFilialActualizadoPor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)

  @@index([filialId])
  @@index([monedaId])
  @@index([usuarioId])
  @@index([anio, mes])
  @@index([filialId, anio, mes])
  @@index([creadoPorId])
  @@index([actualizadoPorId])
  @@map("diezmos_filiales")
}

/// Egresos de la caja general de diezmos filiales
model EgresoFilial {
  id               String    @id @default(cuid())
  fechaSalida      DateTime  @default(now())
  solicitante      String
  monto            Decimal   @db.Decimal(12, 2)
  descripcionGasto String?   @db.Text
  comentario       String?   @db.Text
  creadoEn         DateTime  @default(now())
  actualizadoEn    DateTime  @updatedAt

  monedaId         String
  moneda           Moneda    @relation(fields: [monedaId], references: [id], onDelete: Restrict)

  tipoGastoId      String
  tipoGasto        TipoGasto @relation(fields: [tipoGastoId], references: [id], onDelete: Restrict)

  usuarioId        String
  usuario          Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Restrict)
  
  // Auditoría: quién creó y quién modificó
  creadoPorId      String
  creadoPor        Usuario   @relation("EgresoFilialCreadoPor", fields: [creadoPorId], references: [id], onDelete: Restrict)
  actualizadoPorId String?
  actualizadoPor   Usuario?  @relation("EgresoFilialActualizadoPor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)

  @@index([monedaId])
  @@index([tipoGastoId])
  @@index([usuarioId])
  @@index([fechaSalida])
  @@index([creadoEn])
  @@index([creadoPorId])
  @@index([actualizadoPorId])
  @@map("egresos_filiales")
}

// =====================
// MODELOS PRINCIPALES
// =====================

/// Roles del sistema con permisos configurables
model Rol {
  id            String    @id @default(cuid())
  nombre        String    @unique // Admin, Contador, Tesorero, Capturista
  descripcion   String?
  esAdmin       Boolean   @default(false) // Rol con acceso total
  activo        Boolean   @default(true)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  creadoPorId   String?
  creadoPor     Usuario?  @relation("RolCreadoPor", fields: [creadoPorId], references: [id], onDelete: SetNull)
  actualizadoPorId String?
  actualizadoPor Usuario? @relation("RolActualizadoPor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)

  usuarios      Usuario[]
  permisos      RolPermiso[]

  @@index([activo])
  @@index([creadoPorId])
  @@index([actualizadoPorId])
  @@map("roles")
}

/// Permisos disponibles en el sistema (módulos)
model Permiso {
  id            String    @id @default(cuid())
  modulo        String    @unique // dashboard, ingresos, egresos, cajas, reportes, configuracion, filiales, donaciones
  nombre        String    // Nombre descriptivo del módulo
  descripcion   String?
  orden         Int       @default(0)
  activo        Boolean   @default(true)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  creadoPorId   String?
  creadoPor     Usuario?  @relation("PermisoCreadoPor", fields: [creadoPorId], references: [id], onDelete: SetNull)
  actualizadoPorId String?
  actualizadoPor Usuario? @relation("PermisoActualizadoPor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)

  roles         RolPermiso[]

  @@index([activo, orden])
  @@index([creadoPorId])
  @@index([actualizadoPorId])
  @@map("permisos")
}

/// Relación entre roles y permisos (qué módulos puede acceder cada rol)
model RolPermiso {
  id            String    @id @default(cuid())
  rolId         String
  permisoId     String
  puedeVer      Boolean   @default(true)   // Ver/listar
  puedeCrear    Boolean   @default(false)  // Crear nuevos registros
  puedeEditar   Boolean   @default(false)  // Editar registros existentes
  puedeEliminar Boolean   @default(false)  // Eliminar registros
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt

  rol           Rol       @relation(fields: [rolId], references: [id], onDelete: Cascade)
  permiso       Permiso   @relation(fields: [permisoId], references: [id], onDelete: Cascade)

  @@unique([rolId, permisoId])
  @@index([rolId])
  @@index([permisoId])
  @@map("roles_permisos")
}

/// Usuarios del sistema con acceso al dashboard
model Usuario {
  id            String    @id @default(cuid())
  nombre        String
  apellido      String
  correo        String    @unique
  contrasena    String
  activo        Boolean   @default(true)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt

  rolId         String?
  rol           Rol?      @relation(fields: [rolId], references: [id], onDelete: Restrict)

  ingresos Ingreso[]
  egresos  Egreso[]
  diezmosFiliales  DiezmoFilial[]
  egresosFiliales  EgresoFilial[]
  donaciones       Donacion[]
  auditoriasRealizadas AuditoriaLog[]

  // Auditoría - Relaciones para rastrear quién creó/modificó configuraciones
  monedasCreadas Moneda[] @relation("MonedaCreadoPor")
  monedasModificadas Moneda[] @relation("MonedaActualizadoPor")
  sociedadesCreadas Sociedad[] @relation("SociedadCreadoPor")
  sociedadesModificadas Sociedad[] @relation("SociedadActualizadoPor")
  tiposServicioCreados TipoServicio[] @relation("TipoServicioCreadoPor")
  tiposServicioModificados TipoServicio[] @relation("TipoServicioActualizadoPor")
  tiposIngresoCreados TipoIngreso[] @relation("TipoIngresoCreadoPor")
  tiposIngresoModificados TipoIngreso[] @relation("TipoIngresoActualizadoPor")
  tiposGastoCreados TipoGasto[] @relation("TipoGastoCreadoPor")
  tiposGastoModificados TipoGasto[] @relation("TipoGastoActualizadoPor")
  paisesCreados Pais[] @relation("PaisCreadoPor")
  paisesModificados Pais[] @relation("PaisActualizadoPor")
  filialesCreadas Filial[] @relation("FilialCreadoPor")
  filialesModificadas Filial[] @relation("FilialActualizadoPor")
  cajasCreadas Caja[] @relation("CajaCreadoPor")
  cajasModificadas Caja[] @relation("CajaActualizadoPor")
  rolesCreados Rol[] @relation("RolCreadoPor")
  rolesModificados Rol[] @relation("RolActualizadoPor")
  permisosCreados Permiso[] @relation("PermisoCreadoPor")
  permisosModificados Permiso[] @relation("PermisoActualizadoPor")

  // Auditoría - Relaciones para transactional tables (ingresos, egresos, donaciones, diezmos)
  ingresosCreados Ingreso[] @relation("IngresoCreadoPor")
  ingresosModificados Ingreso[] @relation("IngresoActualizadoPor")
  egresosCreados Egreso[] @relation("EgresoCreadoPor")
  egresosModificados Egreso[] @relation("EgresoActualizadoPor")
  donacionesCreadas Donacion[] @relation("DonacionCreadoPor")
  donacionesModificadas Donacion[] @relation("DonacionActualizadoPor")
  diezmosFilialesCreados DiezmoFilial[] @relation("DiezmoFilialCreadoPor")
  diezmosFilialesModificados DiezmoFilial[] @relation("DiezmoFilialActualizadoPor")
  egresosFilialesCreados EgresoFilial[] @relation("EgresoFilialCreadoPor")
  egresosFilialesModificados EgresoFilial[] @relation("EgresoFilialActualizadoPor")

  // Índice para filtrar usuarios activos y login
  @@index([activo])
  @@index([correo, activo])
  @@index([rolId])
  @@map("usuarios")
}

/// Cajas contables - cada caja maneja su propio dinero
model Caja {
  id            String    @id @default(cuid())
  nombre        String    @unique
  descripcion   String?
  activa        Boolean   @default(true)
  esGeneral     Boolean   @default(false) // Caja que recibe ofrendas generales sin importar sociedad
  orden         Int       @default(0)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  creadoPorId   String?
  creadoPor     Usuario?  @relation("CajaCreadoPor", fields: [creadoPorId], references: [id], onDelete: SetNull)
  actualizadoPorId String?
  actualizadoPor Usuario? @relation("CajaActualizadoPor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)

  // Asignación automática (opcional)
  sociedadId    String?
  sociedad      Sociedad?    @relation(fields: [sociedadId], references: [id], onDelete: SetNull)
  
  tipoIngresoId String?
  tipoIngreso   TipoIngreso? @relation(fields: [tipoIngresoId], references: [id], onDelete: SetNull)

  // Relaciones con ingresos (principal y secundaria para tracking)
  ingresos            Ingreso[] @relation("CajaPrincipal")
  ingresosSecundarios Ingreso[] @relation("CajaSecundaria")
  egresos             Egreso[]
  donaciones          Donacion[]

  @@index([sociedadId])
  @@index([tipoIngresoId])
  // Índices para filtrar cajas activas
  @@index([activa, orden])
  @@index([activa, esGeneral])
  @@index([creadoPorId])
  @@index([actualizadoPorId])
  @@map("cajas")
}

/// Montos de ingresos por moneda
model IngresoMonto {
  id        String   @id @default(cuid())
  monto     Decimal  @db.Decimal(12, 2)
  
  ingresoId String
  ingreso   Ingreso  @relation(fields: [ingresoId], references: [id], onDelete: Cascade)
  
  monedaId  String
  moneda    Moneda   @relation(fields: [monedaId], references: [id], onDelete: Restrict)

  @@unique([ingresoId, monedaId])
  @@index([ingresoId])
  @@index([monedaId])
  @@map("ingreso_montos")
}

/// Registro de ingresos (recaudación de dinero)
model Ingreso {
  id               String    @id @default(cuid())
  fechaRecaudacion DateTime  @default(now())
  comentario       String?   @db.Text
  creadoEn         DateTime  @default(now())
  actualizadoEn    DateTime  @updatedAt
  creadoPorId      String
  creadoPor        Usuario   @relation("IngresoCreadoPor", fields: [creadoPorId], references: [id], onDelete: Restrict)
  actualizadoPorId String?
  actualizadoPor   Usuario?  @relation("IngresoActualizadoPor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)
  
  // Relaciones con tablas de configuración
  sociedadId    String
  sociedad      Sociedad     @relation(fields: [sociedadId], references: [id], onDelete: Restrict)
  
  servicioId    String
  servicio      TipoServicio @relation(fields: [servicioId], references: [id], onDelete: Restrict)
  
  tipoIngresoId String
  tipoIngreso   TipoIngreso  @relation(fields: [tipoIngresoId], references: [id], onDelete: Restrict)
  
  // Caja principal donde está el dinero físicamente
  cajaId        String
  caja          Caja         @relation("CajaPrincipal", fields: [cajaId], references: [id], onDelete: Restrict)
  
  // Caja secundaria para tracking por sociedad (opcional, no afecta saldo real)
  cajaSecundariaId String?
  cajaSecundaria   Caja?    @relation("CajaSecundaria", fields: [cajaSecundariaId], references: [id], onDelete: SetNull)
  
  usuarioId     String
  usuario       Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  montos        IngresoMonto[]

  @@index([cajaId])
  @@index([cajaSecundariaId])
  @@index([usuarioId])
  @@index([creadoPorId])
  @@index([actualizadoPorId])
  @@index([sociedadId])
  @@index([servicioId])
  @@index([tipoIngresoId])
  @@index([fechaRecaudacion])
  // Índices compuestos para consultas de reportes y dashboard
  @@index([cajaId, fechaRecaudacion])
  @@index([cajaSecundariaId, fechaRecaudacion])
  @@index([sociedadId, fechaRecaudacion])
  @@index([fechaRecaudacion, cajaId, sociedadId])
  @@index([creadoEn]) // Para ordenar últimos movimientos
  @@map("ingresos")
}

/// Registro de egresos (salidas de dinero)
model Egreso {
  id               String    @id @default(cuid())
  fechaSalida      DateTime  @default(now())
  solicitante      String
  monto            Decimal   @db.Decimal(12, 2)
  descripcionGasto String?   @db.Text
  comentario       String?   @db.Text
  creadoEn         DateTime  @default(now())
  actualizadoEn    DateTime  @updatedAt
  
  // Relaciones con tablas de configuración
  tipoGastoId   String
  tipoGasto     TipoGasto @relation(fields: [tipoGastoId], references: [id], onDelete: Restrict)
  
  monedaId      String
  moneda        Moneda    @relation(fields: [monedaId], references: [id], onDelete: Restrict)
  
  cajaId        String
  caja          Caja      @relation(fields: [cajaId], references: [id], onDelete: Restrict)
  
  usuarioId     String
  usuario       Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Restrict)
  
  // Auditoría: quién creó y quién modificó
  creadoPorId      String
  creadoPor        Usuario   @relation("EgresoCreadoPor", fields: [creadoPorId], references: [id], onDelete: Restrict)
  actualizadoPorId String?
  actualizadoPor   Usuario?  @relation("EgresoActualizadoPor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)

  @@index([cajaId])
  @@index([usuarioId])
  @@index([tipoGastoId])
  @@index([monedaId])
  @@index([fechaSalida])
  @@index([creadoPorId])
  @@index([actualizadoPorId])
  // Índices compuestos para consultas de reportes y dashboard
  @@index([cajaId, fechaSalida])
  @@index([cajaId, monedaId])
  @@index([fechaSalida, cajaId])
  @@index([tipoGastoId, monedaId])
  @@index([creadoEn]) // Para ordenar últimos movimientos
  @@map("egresos")
}

// =====================
// MÓDULO DE DONACIONES
// =====================

/// Registro de donaciones (siempre van a la Caja General)
model Donacion {
  id            String    @id @default(cuid())
  nombre        String    // Nombre del donante
  telefono      String?   // Teléfono del donante
  fecha         DateTime  @default(now())
  monto         Decimal   @db.Decimal(12, 2)
  comentario    String?   @db.Text
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  
  // Relaciones
  tipoOfrendaId String
  tipoOfrenda   TipoIngreso @relation(fields: [tipoOfrendaId], references: [id], onDelete: Restrict)
  
  monedaId      String
  moneda        Moneda    @relation(fields: [monedaId], references: [id], onDelete: Restrict)
  
  // La donación siempre va a la Caja General (la que tiene esGeneral=true)
  cajaId        String
  caja          Caja      @relation(fields: [cajaId], references: [id], onDelete: Restrict)
  
  usuarioId     String
  usuario       Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Restrict)
  
  // Auditoría: quién creó y quién modificó
  creadoPorId      String
  creadoPor        Usuario   @relation("DonacionCreadoPor", fields: [creadoPorId], references: [id], onDelete: Restrict)
  actualizadoPorId String?
  actualizadoPor   Usuario?  @relation("DonacionActualizadoPor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)

  @@index([cajaId])
  @@index([usuarioId])
  @@index([tipoOfrendaId])
  @@index([monedaId])
  @@index([fecha])
  @@index([nombre])
  @@index([creadoEn])
  @@index([creadoPorId])
  @@index([actualizadoPorId])
  @@map("donaciones")
}

// =====================
// AUDITORÍA Y CONTROL
// =====================

/// Log de auditoría para cambios en configuración
model AuditoriaLog {
  id              String    @id @default(cuid())
  tabla           String    // Nombre de la tabla: "Moneda", "Sociedad", "Caja", etc.
  registroId      String    // ID del registro que se modificó
  operacion       String    // "CREATE", "UPDATE", "DELETE"
  datoAnterior    Json?     // Datos antes del cambio (null para CREATE)
  datoNuevo       Json?     // Datos después del cambio (null para DELETE)
  descripcion     String?   @db.Text // Resumen legible del cambio
  fechaOperacion  DateTime  @default(now())
  
  usuarioId       String
  usuario         Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Restrict)
  
  @@index([usuarioId])
  @@index([tabla])
  @@index([registroId])
  @@index([operacion])
  @@index([fechaOperacion])
  @@index([tabla, registroId])
  @@index([usuarioId, fechaOperacion])
  @@map("auditoria_logs")
}
